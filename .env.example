# Telegram Bot Configuration
# Retrieve token from @BotFather
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Groq AI Configurations
# Retrieve key from https://console.groq.com/
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL=llama-3.3-70b-versatile

# Server Port (Render automatically sets this)
PORT=3000

# Webhook deployment URL (Leave blank for local polling mode)
# Example: https://astraos-core.onrender.com
WEBHOOK_URL=
